)
)
server <- function(input, output, session) {
output$plot <- renderPlot({
ggplot(data = elephants, aes(x = .data[[input$x]], y = sex, fill = sex)) +
geom_boxplot() +
theme(
legend.position = "none"
) +
observe(input$x) +
observeEvent(input$x, {
if (input$x == "age") {
labs(
x = "Age (yrs)"
)
} else {
labs(
x = "Height (cm)"
)
} +
theme_minimal()
})
})
shinyApp(ui, server)
